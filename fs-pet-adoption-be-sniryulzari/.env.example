# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# JWT signing secret — use a long random string (min 32 chars)
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
TOKEN_SECRET=<replace_with_long_random_string>

# Server port (defaults to 8080 if omitted)
PORT=8080

# Node environment — set to "production" on the server
NODE_ENV=development

# Frontend origin allowed by CORS and used in outbound email links
FRONTEND_URL=http://localhost:3000

# Cloudinary (image uploads)
CLOUD_NAME=<your_cloud_name>
CLOUDINARY_API_KEY=<your_api_key>
CLOUDINARY_API_SECRET=<your_api_secret>

# Brevo (email delivery)
BREVO_API_KEY=<your_brevo_api_key>
EMAIL_FROM=<verified_sender_email@example.com>
