# Backend URL — set this in the Vercel dashboard under Project → Settings → Environment Variables
# The value must be your Railway backend URL (e.g. https://ado-pet-production.up.railway.app)
# CRA bakes REACT_APP_* variables into the bundle at build time, so it must be set before deploying.
REACT_APP_API_URL=https://<your-railway-service>.up.railway.app
